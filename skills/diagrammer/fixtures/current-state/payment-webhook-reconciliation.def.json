  "annotations": [
    {
      "title": "What this tests",
      "lines": [
        "checkout fans out to provider, ledger, and risk paths",
        "provider, ledger, and risk paths converge into one queue",
        "worker writes to DB, notifies customer, and handles retry"
      ],
      "lane": 3,
      "rank": 0
    }
  ],
  "assumptions": [
    "Provider callbacks are normalized through the payment events queue",
    "Reconciler owns repair and retry behavior"
  ],
  "notImplied": [
    "No exact payment-provider API contract is implied",
    "No exactly-once event delivery guarantee is shown"
  ]
